{
  "rewrites": [
    { "source": "/haldus", "destination": "/haldus.html" },
    { "source": "/haldus/", "destination": "/haldus.html" },
    { "source": "/privaatsus", "destination": "/privaatsus.html" },
    { "source": "/privaatsus/", "destination": "/privaatsus.html" },
    { "source": "/tingimused", "destination": "/tingimused.html" },
    { "source": "/tingimused/", "destination": "/tingimused.html" },
    { "source": "/kutse", "destination": "/kutse.html" },
    { "source": "/", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}

{
  "rewrites": [
    { "source": "/haldus", "destination": "/haldus.html" },
    { "source": "/haldus/", "destination": "/haldus.html" },
    { "source": "/haldus-exercises", "destination": "/haldus-exercises/index.html" },
    { "source": "/haldus-exercises/", "destination": "/haldus-exercises/index.html" },
    { "source": "/tasemetest", "destination": "/tasemetest.html" },
    { "source": "/tasemetest/", "destination": "/tasemetest.html" },
    { "source": "/privaatsus", "destination": "/privaatsus.html" },
    { "source": "/privaatsus/", "destination": "/privaatsus.html" },
    { "source": "/tingimused", "destination": "/tingimused.html" },
    { "source": "/tingimused/", "destination": "/tingimused.html" },
    { "source": "/kutse", "destination": "/kutse" },
    { "source": "/", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/haldus-exercises",
      "headers": [{ "key": "Content-Type", "value": "text/html; charset=utf-8" }]
    },
    {
      "source": "/haldus-exercises/",
      "headers": [{ "key": "Content-Type", "value": "text/html; charset=utf-8" }]
    },
    {
      "source": "/tasemetest",
      "headers": [{ "key": "Content-Type", "value": "text/html; charset=utf-8" }]
    },
    {
      "source": "/tasemetest/",
      "headers": [{ "key": "Content-Type", "value": "text/html; charset=utf-8" }]
    },
    {
      "source": "/privaatsus",
      "headers": [{ "key": "Content-Type", "value": "text/html; charset=utf-8" }]
    },
    {
      "source": "/privaatsus/",
      "headers": [{ "key": "Content-Type", "value": "text/html; charset=utf-8" }]
    },
    {
      "source": "/tingimused",
      "headers": [{ "key": "Content-Type", "value": "text/html; charset=utf-8" }]
    },
    {
      "source": "/tingimused/",
      "headers": [{ "key": "Content-Type", "value": "text/html; charset=utf-8" }]
    },
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    },
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
    },
    {
      "source": "/(.*)",
      "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }]
    }
  ]
}
